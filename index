        function changeModel(model) {
            currentModel = model;
            document.getElementById('btn-model-lego').className = model === 'lego' ? 'flex-1 py-3 text-center font-bold rounded-lg transition-all text-blue-950 bg-blue-50 border border-blue-200' : 'flex-1 py-3 text-center font-bold rounded-lg transition-all text-gray-500 hover:bg-gray-50';
            document.getElementById('btn-model-store').className = model === 'storeplatform' ? 'flex-1 py-3 text-center font-bold rounded-lg transition-all text-blue-950 bg-blue-50 border border-blue-200' : 'flex-1 py-3 text-center font-bold rounded-lg transition-all text-gray-500 hover:bg-gray-50';
            
            currentChannel = db[model].channels[0];
            buildChannels();
            buildForm();
            calculateScores();
        }

        function buildChannels() {
            const container = document.getElementById('channel-container');
            container.innerHTML = '';
            db[currentModel].channels.forEach(ch => {
                const active = ch === currentChannel ? 'bg-blue-900 text-white shadow-xs' : 'bg-gray-100 hover:bg-gray-200 text-gray-700';
                container.innerHTML += `<button onclick="setChannel('${ch}')" class="py-2 text-center text-xs font-bold rounded-md transition-all ${active}">${ch}</button>`;
            });
        }

        function setChannel(ch) {
            currentChannel = ch;
            buildChannels();
            calculateScores();
        }

        function buildForm() {
            const container = document.getElementById('checklist-form');
            container.innerHTML = '';
            
            const sections = db[currentModel].items;
            for (let sectionName in sections) {
                let html = `
                    <div class="bg-white rounded-xl shadow-xs border border-gray-200 overflow-hidden">
                        <div class="${colors[sectionName]} px-4 py-2.5 text-white font-bold text-sm tracking-wide flex justify-between items-center">
                            <span>${sectionName === 'CKO' ? 'CKO / CKT' : sectionName}</span>
                            <span class="text-xs bg-black/20 px-2 py-0.5 rounded-sm" id="section-total-${sectionName}">0 pts</span>
                        </div>
                        <div class="divide-y divide-gray-100">
                `;

                sections[sectionName].forEach(item => {
                    const val = item.scores[currentChannel] || 0;
                    const isVisible = val > 0;
                    
                    html += `
                        <div class="p-3 flex items-center justify-between gap-4 ${isVisible ? '' : 'bg-gray-50/50 opacity-60'}">
                            <div class="flex-1">
                                <p class="text-sm font-semibold text-gray-800">${item.name}</p>
                                <p class="text-xs text-gray-400 font-medium">Peso neste canal: ${val} pts</p>
                            </div>
                            <div class="flex gap-1.5 shrink-0">
                                <button onclick="setResponse('${item.id}', true)" id="btn-sim-${item.id}" class="btn-sim px-3.5 py-1.5 border border-gray-300 rounded-lg text-xs font-bold text-gray-600 transition-all ${responses[item.id] === true ? 'active' : ''}">SIM</button>
                                <button onclick="setResponse('${item.id}', false)" id="btn-nao-${item.id}" class="btn-nao px-3.5 py-1.5 border border-gray-300 rounded-lg text-xs font-bold text-gray-600 transition-all ${responses[item.id] === false ? 'active' : ''}">NÃO</button>
                            </div>
                        </div>
                    `;
                });

                html += `</div></div>`;
                container.innerHTML += html;
            }
        }

        function setResponse(id, value) {
            responses[id] = value;
            
            const btnSim = document.getElementById(`btn-sim-${id}`);
            const btnNao = document.getElementById(`btn-nao-${id}`);
            
            if (value) {
                btnSim.classList.add('active');
                btnNao.classList.remove('active');
            } else {
                btnSim.classList.remove('active');
                btnNao.classList.add('active');
            }
            calculateScores();
        }

        function calculateScores() {
            let totals = { SOS: { got: 0, max: 0 }, CKO: { got: 0, max: 0 }, PE: { got: 0, max: 0 }, KBDs: { got: 0, max: 0 } };
            
            const sections = db[currentModel].items;
            for (let sec in sections) {
                sections[sec].forEach(item => {
                    const weight = item.scores[currentChannel] || 0;
                    if (weight > 0) {
                        totals[sec].max += weight;
                        if (responses[item.id] === true) {
                            totals[sec].got += weight;
                        }
                    }
                });
                
                const lbl = document.getElementById(`section-total-${sec}`);
                if (lbl) lbl.innerText = `${totals[sec].got} / ${totals[sec].max} pts`;
            }

            document.getElementById('dash-sos').innerText = `${totals.SOS.got} / ${totals.SOS.max}`;
            document.getElementById('dash-cko').innerText = `${totals.CKO.got} / ${totals.CKO.max}`;
            document.getElementById('dash-pe').innerText = `${totals.PE.got} / ${totals.PE.max}`;
            document.getElementById('dash-kbds').innerText = `${totals.KBDs.got} / ${totals.KBDs.max}`;
            
            const grandTotalGot = totals.SOS.got + totals.CKO.got + totals.PE.got + totals.KBDs.got;
            const grandTotalMax = totals.SOS.max + totals.CKO.max + totals.PE.max + totals.KBDs.max;
            
            document.getElementById('dash-total').innerText = `${grandTotalGot} / ${grandTotalMax}`;
        }

        function clearForm() {
            if(confirm("Deseja mesmo zerar todo o questionário atual?")) {
                responses = {};
                buildForm();
                calculateScores();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        }

        function shareReport() {
            let totals = { SOS: { got: 0, max: 0 }, CKO: { got: 0, max: 0 }, PE: { got: 0, max: 0 }, KBDs: { got: 0, max: 0 } };
            const sections = db[currentModel].items;
            
            for (let sec in sections) {
                sections[sec].forEach(item => {
                    const weight = item.scores[currentChannel] || 0;
                    if (weight > 0) {
                        totals[sec].max += weight;
                        if (responses[item.id] === true) totals[sec].got += weight;
                    }
                });
            }
            
            const totalGot = totals.SOS.got + totals.CKO.got + totals.PE.got + totals.KBDs.got;
            const totalMax = totals.SOS.max + totals.CKO.max + totals.PE.max + totals.KBDs.max;
            const aproveitamento = totalMax > 0 ? ((totalGot / totalMax) * 100).toFixed(1) : 0;

            let text = `📊 *RESULTADO DA AUDITORIA*\n`;
            text += `*Modelo:* ${currentModel.toUpperCase()}\n`;
            text += `*Canal:* ${currentChannel}\n`;
            text += `----------------------------------\n`;
            text += `🔸 *SOS:* ${totals.SOS.got} / ${totals.SOS.max}\n`;
            text += `🔸 *CKO/CKT:* ${totals.CKO.got} / ${totals.CKO.max}\n`;
            text += `🔸 *PE:* ${totals.PE.got} / ${totals.PE.max}\n`;
            text += `🔸 *KBDs:* ${totals.KBDs.got} / ${totals.KBDs.max}\n`;
            text += `----------------------------------\n`;
            text += `🏆 *PONTUAÇÃO TOTAL:* *${totalGot} / ${totalMax}*\n`;
            text += `📈 *APROVEITAMENTO:* *${aproveitamento}%*`;

            navigator.clipboard.writeText(text).then(() => {
                alert("Relatório copiado para a Área de Transferência! Agora basta colar no WhatsApp.");
            }).catch(() => {
                alert("Erro ao copiar automaticamente. Use os recursos nativos do dispositivo.");
            });
        }

        changeModel('lego');
    </script>
</body>
</html>
