            <h1 class="text-xl font-bold tracking-wide flex items-center gap-2">
                <i class="fa-solid fa-chart-line text-yellow-400"></i> Simulador de Pontuação
            </h1>
            <span class="text-xs bg-blue-800 px-3 py-1 rounded-full border border-blue-700">V4.0</span>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 mt-4 space-y-6">

        <div class="bg-white rounded-xl shadow-sm p-2 flex border border-gray-200">
            <button onclick="changeModel('lego')" id="btn-model-lego" class="flex-1 py-3 text-center font-bold rounded-lg transition-all text-blue-950 bg-blue-50">
                <i class="fa-solid fa-cubes mr-2 text-blue-600"></i>LEGO (Diretos)
            </button>
            <button onclick="changeModel('storeplatform')" id="btn-model-store" class="flex-1 py-3 text-center font-bold rounded-lg transition-all text-gray-500 hover:bg-gray-50">
                <i class="fa-solid fa-shop mr-2 text-gray-400"></i>Storeplatform (Indiretos)
            </button>
        </div>

        <div class="bg-white rounded-xl shadow-sm p-4 border border-gray-200">
            <label class="block text-xs font-bold uppercase tracking-wider text-gray-500 mb-2">Canal da Loja</label>
            <div id="channel-container" class="grid grid-cols-5 gap-2">
                </div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
            <div class="bg-amber-50 border border-amber-200 rounded-xl p-3 text-center shadow-xs">
                <p class="text-xs font-bold text-amber-800">SOS</p>
                <p class="text-xl font-black text-amber-950" id="dash-sos">0 / 0</p>
            </div>
            <div class="bg-purple-50 border border-purple-200 rounded-xl p-3 text-center shadow-xs">
                <p class="text-xs font-bold text-purple-800">CKO / CKT</p>
                <p class="text-xl font-black text-purple-950" id="dash-cko">0 / 0</p>
            </div>
            <div class="bg-cyan-50 border border-cyan-200 rounded-xl p-3 text-center shadow-xs">
                <p class="text-xs font-bold text-cyan-800">PE</p>
                <p class="text-xl font-black text-cyan-950" id="dash-pe">0 / 0</p>
            </div>
            <div class="bg-green-50 border border-green-200 rounded-xl p-3 text-center shadow-xs">
                <p class="text-xs font-bold text-green-800">KBDs</p>
                <p class="text-xl font-black text-green-950" id="dash-kbds">0 / 0</p>
            </div>
            <div class="bg-blue-900 rounded-xl p-3 text-center col-span-2 sm:col-span-1 text-white shadow-md">
                <p class="text-xs font-bold text-blue-200">Total Loja</p>
                <p class="text-2xl font-black text-yellow-400" id="dash-total">0 / 0</p>
            </div>
        </div>

        <div id="checklist-form" class="space-y-6">
            </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4">
            <button onclick="clearForm()" class="bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold py-3.5 px-4 rounded-xl transition-all shadow-xs flex items-center justify-center gap-2">
                <i class="fa-solid fa-trash-can"></i> Limpar Questionário
            </button>
            <button onclick="shareReport()" class="bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3.5 px-4 rounded-xl transition-all shadow-md flex items-center justify-center gap-2">
                <i class="fa-brands fa-whatsapp text-lg"></i> Copiar Relatório WhatsApp
